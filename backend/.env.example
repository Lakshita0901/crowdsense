# CrowdSense AI — Backend Environment Variables
# Copy this file to .env and fill in your values.

# ── Google Gemini ────────────────────────────────────────────────────────────
# Required for /api/fan/chat to use Gemini 2.5 Flash.
# Without this key the endpoint still works, falling back to FAISS-only synthesis.
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_key_here

# ── Optional: override server settings ─────────────────────────────────────
# PORT=8000
# HOST=0.0.0.0
